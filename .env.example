# OpenAI — executive summary on Insights + AI architecture recommendations
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Default if unset: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional: Azure OpenAI or OpenAI-compatible proxy base URL
# OPENAI_BASE_URL=

# Hugging Face — optional document narrative analysis after text extraction
# Get a token from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
# Default if unset: facebook/bart-large-cnn
# HF_TEXT_ANALYSIS_MODEL=facebook/bart-large-cnn
# Reference document parsing model (MinerU 2.5 Pro pipeline)
# HF_DOCUMENT_MODEL=opendatalab/MinerU2.5-Pro-2604-1.2B

# Resend — optional PDF email delivery for architect assessments
# https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender domain in Resend (e.g. AI Arena <reports@yourdomain.com>)
RESEND_FROM_EMAIL=

# Supabase — persistent database (production / shared workshops)
# Create project at https://supabase.com then run supabase/migrations/001_arena_schema.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side writes (recommended for API routes; keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Without Supabase, the app stores data locally in data/arena-state.json and data/arena-history.json
